generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AppStatus {
  PENDING
  REVIEWED
  INTERVIEWED
  ACCEPTED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(USER)
  avatar        String?
  phone         String?
  cvText        String?
  isBlocked     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  applications  Application[]
  company       Company?
  cv            CV?
  favorites     Favorite[]
  reports       JobReport[]
  notifications Notification[]
  userReports   UserReport[]   @relation("ReportedUser")
  reportsMade   UserReport[]   @relation("ReportingUser")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  description String?
  industry    String?
  location    String?
  size        String?
  verified    Boolean  @default(false)
  website     String?
  createdAt   DateTime @default(now())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs        Job[]
}

model Job {
  id            String        @id @default(cuid())
  title         String
  description   String
  requirements  String?
  benefits      String?
  salaryMin     Int?
  salaryMax     Int?
  location      String
  type          JobType       @default(FULL_TIME)
  category      String
  contactPhone  String?
  recruiterName String?
  phoneNumber   String?
  kakaoId       String?
  status        JobStatus     @default(PENDING)
  featured      Boolean       @default(false)
  views         Int           @default(0)
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications  Application[]
  favorites     Favorite[]
  reports       JobReport[]

  @@index([status])
  @@index([companyId])
  @@index([status, featured])
  @@index([category])
  @@index([expiresAt])
}

model Application {
  id        String    @id @default(cuid())
  status    AppStatus @default(PENDING)
  message   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
}

model CV {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  phone            String?
  email            String
  dateOfBirth      String?
  gender           String?
  nationality      String?
  education        String?
  experience       String?
  skills           String?
  selfIntroduction String?
  resumeUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model JobReport {
  id          String   @id @default(cuid())
  jobId       String
  userId      String
  reason      String
  description String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model UserReport {
  id             String   @id @default(cuid())
  reportedUserId String
  reportedBy     String
  reason         String
  description    String?
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())
  reportedUser   User     @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter       User     @relation("ReportingUser", fields: [reportedBy], references: [id], onDelete: Cascade)

  @@index([reportedUserId])
  @@index([status])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
